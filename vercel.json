{
  "version": 2,
  "installCommand": "npm ci --legacy-peer-deps",
  "buildCommand": "CI=false npm run build",
  "outputDirectory": "build",
  "framework": null,
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.py" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}